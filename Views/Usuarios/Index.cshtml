@model IEnumerable<LabControl.Models.Usuario>
@{
    ViewData["Title"] = "Usuários";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0"><i class="bi bi-people-fill me-2 text-primary"></i>Usuários</h5>
        <small class="text-muted">Gestão de usuários e permissões do sistema</small>
    </div>
    <a asp-action="Criar" class="btn btn-primary btn-sm">
        <i class="bi bi-person-plus me-1"></i>Novo Usuário
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nome / Login</th>
                    <th class="text-center">Tipo</th>
                    <th class="text-center">Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            <i class="bi bi-people fs-4 d-block mb-2"></i>
                            Nenhum usuário cadastrado.
                        </td>
                    </tr>
                }
                @foreach (var u in Model)
                {
                    <tr class="@(u.Inativo ? "table-secondary text-muted" : "")">
                        <td class="fw-semibold align-middle">
                            <i class="bi bi-person-circle me-2 text-secondary"></i>@u.Nome
                        </td>
                        <td class="text-center align-middle">
                            @if (u.IsAdmin)
                            {
                                <span class="badge bg-danger">Administrador</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Normal</span>
                            }
                        </td>
                        <td class="text-center align-middle">
                            @if (u.Inativo)
                            {
                                <span class="badge bg-light text-danger border border-danger">Inativo</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                        </td>
                        <td class="text-end align-middle">
                            <a asp-action="Editar" asp-route-id="@u.Id"
                               class="btn btn-outline-secondary btn-sm me-1" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="AlternarStatus" asp-route-id="@u.Id" method="post"
                                  style="display:inline"
                                  onsubmit="return confirm('@(u.Inativo ? "Ativar" : "Desativar") o usuário @u.Nome?')">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm @(u.Inativo ? "btn-outline-success" : "btn-outline-warning")"
                                        title="@(u.Inativo ? "Ativar" : "Desativar")">
                                    <i class="bi @(u.Inativo ? "bi-toggle-off" : "bi-toggle-on")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Any())
    {
        <div class="card-footer text-muted small">
            @Model.Count() usuário(s) — @Model.Count(u => !u.Inativo) ativo(s)
        </div>
    }
</div>
