@model IEnumerable<LabControl.Models.Laboratorio.Proposta>
@{
    ViewData["Title"] = "Propostas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0"><i class="bi bi-file-text me-2 text-primary"></i>Propostas de Análise</h5>
        <small class="text-muted">Gestão de propostas comerciais</small>
    </div>
    <a asp-action="Criar" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Nova Proposta
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Código</th>
                    <th>Cliente</th>
                    <th>Data Solicitação</th>
                    <th>Validade</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            Nenhuma proposta cadastrada ainda.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="fw-semibold text-primary">@item.CodigoFormatado</span></td>
                        <td>@(item.Entidade?.Nome ?? "-")</td>
                        <td>@item.DtSolicitacao.ToString("dd/MM/yyyy")</td>
                        <td>@(item.DtValidade.HasValue ? item.DtValidade.Value.ToString("dd/MM/yyyy") : "-")</td>
                        <td>
                            <span class="fw-semibold">
                                @(item.Moeda?.Sigla ?? "R$") @item.VrTotal.ToString("N2")
                            </span>
                        </td>
                        <td>
                            @if (item.Status != null)
                            {
                                <span class="badge badge-status" style="background-color: @(item.Status.Cor ?? "#6c757d")">
                                    @item.Status.Descricao
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Detalhes" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Any())
    {
        <div class="card-footer text-muted small">
            Total: @Model.Count() proposta(s)
        </div>
    }
</div>
