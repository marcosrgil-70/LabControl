@model LabControl.Models.Laboratorio.Proposta
@{
    ViewData["Title"] = "Nova Proposta";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0"><i class="bi bi-file-plus me-2 text-primary"></i>Nova Proposta</h5>
        <small class="text-muted">Proposta de análise laboratorial</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<form asp-action="Criar" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold py-2"><i class="bi bi-person me-1"></i>Cliente e Dados Gerais</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">Cliente <span class="text-danger">*</span></label>
                            <select asp-for="IdEntidade" class="form-select form-select-sm" required>
                                <option value="">Selecione o cliente...</option>
                                @foreach (var c in (List<LabControl.Models.Entidades.Entidade>)ViewBag.Clientes)
                                {
                                    <option value="@c.Id">@c.Nome</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ano</label>
                            <input asp-for="AnoProposta" class="form-control form-control-sm" readonly />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Validade</label>
                            <input asp-for="DtValidade" type="date" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Status</label>
                            <select asp-for="IdStatus" class="form-select form-select-sm">
                                <option value="">-</option>
                                @foreach (var s in (List<LabControl.Models.Laboratorio.PropostaStatus>)ViewBag.PropostasStatus)
                                {
                                    <option value="@s.Id">@s.Descricao</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Condição de Pagamento</label>
                            <select asp-for="IdCondicaoPagamento" class="form-select form-select-sm">
                                <option value="">-</option>
                                @foreach (var c in (List<LabControl.Models.Laboratorio.CondicaoPagamento>)ViewBag.CondicoesPagamentos)
                                {
                                    <option value="@c.Id">@c.Descricao</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Moeda</label>
                            <select asp-for="IdMoeda" class="form-select form-select-sm">
                                <option value="">-</option>
                                @foreach (var m in (List<LabControl.Models.Laboratorio.Moeda>)ViewBag.Moedas)
                                {
                                    <option value="@m.Id">@m.Sigla — @m.Descricao</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i>Criar Proposta
            </button>
        </div>
    </div>
</form>
