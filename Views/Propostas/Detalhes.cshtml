@model LabControl.Models.Laboratorio.Proposta
@{
    ViewData["Title"] = $"Proposta {Model.CodigoFormatado}";
    var moedaSigla = Model.Moeda?.Sigla ?? "R$";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0">
            <i class="bi bi-file-text me-2 text-primary"></i>
            Proposta <span class="text-primary">@Model.CodigoFormatado</span>
        </h5>
        <small class="text-muted">
            @if (Model.Status != null)
            {
                <span class="badge" style="background-color:@(Model.Status.Cor ?? "#6c757d")">@Model.Status.Descricao</span>
            }
        </small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<div class="row g-3">
    <!-- Cabeçalho da proposta -->
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header fw-semibold py-2"><i class="bi bi-person me-1"></i>Dados da Proposta</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-4 text-muted">Cliente</dt>
                    <dd class="col-8 fw-semibold">@Model.Entidade?.Nome</dd>

                    <dt class="col-4 text-muted">Solicitação</dt>
                    <dd class="col-8">@Model.DtSolicitacao.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-4 text-muted">Validade</dt>
                    <dd class="col-8">@(Model.DtValidade?.ToString("dd/MM/yyyy") ?? "-")</dd>

                    <dt class="col-4 text-muted">Cond. Pagamento</dt>
                    <dd class="col-8">@(Model.CondicaoPagamento?.Descricao ?? "-")</dd>

                    <dt class="col-4 text-muted">Moeda</dt>
                    <dd class="col-8">@(Model.Moeda?.Descricao ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Totais -->
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header fw-semibold py-2"><i class="bi bi-calculator me-1"></i>Totais</div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Subtotal</span>
                    <span>@moedaSigla @(Model.Analises.Sum(a => a.VrTotal).ToString("N2"))</span>
                </div>
                @if (Model.PorcDesconto.HasValue && Model.PorcDesconto > 0)
                {
                    <div class="d-flex justify-content-between mb-2 text-danger">
                        <span>Desconto (@Model.PorcDesconto.Value.ToString("N1")%)</span>
                        <span>- @moedaSigla @(Model.VrDesconto?.ToString("N2") ?? "0,00")</span>
                    </div>
                }
                <hr class="my-2" />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span class="text-primary">@moedaSigla @Model.VrTotal.ToString("N2")</span>
                </div>

                <!-- Aplicar desconto -->
                <form asp-action="AplicarDesconto" asp-route-id="@Model.Id" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">Desconto %</span>
                        <input type="number" name="porcDesconto" step="0.1" min="0" max="100"
                               class="form-control" value="@(Model.PorcDesconto ?? 0)" />
                        <button type="submit" class="btn btn-outline-primary">Aplicar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Itens da proposta -->
    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold py-2 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-list-ul me-1"></i>Itens de Análise</span>
                <button class="btn btn-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#formItem">
                    <i class="bi bi-plus-circle me-1"></i>Adicionar Item
                </button>
            </div>

            <!-- Formulário inline de adição de item -->
            <div class="collapse" id="formItem">
                <div class="card-body border-bottom bg-light">
                    <form asp-action="AdicionarItem" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="idProposta" value="@Model.Id" />
                        <div class="row g-2 align-items-end">
                            <div class="col-md-3">
                                <label class="form-label form-label-sm">Produto</label>
                                <select name="idProduto" class="form-select form-select-sm">
                                    <option value="">-</option>
                                    @foreach (var p in (List<LabControl.Models.Laboratorio.Produto>)ViewBag.Produtos)
                                    {
                                        <option value="@p.Id">@p.Descricao</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label form-label-sm">Tipo de Análise</label>
                                <select name="idAnaliseTipo" class="form-select form-select-sm">
                                    <option value="">-</option>
                                    @foreach (var a in (List<LabControl.Models.Laboratorio.AnaliseTipo>)ViewBag.AnalisesTipos)
                                    {
                                        <option value="@a.Id">@a.Descricao</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label form-label-sm">Método</label>
                                <select name="idAnaliseMetodo" class="form-select form-select-sm">
                                    <option value="">-</option>
                                    @foreach (var m in (List<LabControl.Models.Laboratorio.AnaliseMetodo>)ViewBag.AnalisesMetodos)
                                    {
                                        <option value="@m.Id">@m.Descricao</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-1">
                                <label class="form-label form-label-sm">Qtde</label>
                                <input name="qtde" type="number" min="1" value="1" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label form-label-sm">Vr. Unitário</label>
                                <input name="vrUnitario" type="number" step="0.01" min="0" value="0" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-1">
                                <label class="form-label form-label-sm">Desconto</label>
                                <input name="vrDesconto" type="number" step="0.01" min="0" value="0" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-1">
                                <button type="submit" class="btn btn-success btn-sm w-100">
                                    <i class="bi bi-plus"></i> Add
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tabela de itens -->
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Produto</th>
                            <th>Tipo de Análise</th>
                            <th>Método</th>
                            <th class="text-center">Qtde</th>
                            <th class="text-end">Vr. Unit.</th>
                            <th class="text-end">Desconto</th>
                            <th class="text-end">Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Analises.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-3">
                                    Nenhum item adicionado. Clique em "Adicionar Item".
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model.Analises)
                        {
                            <tr>
                                <td>@(item.Produto?.Descricao ?? "-")</td>
                                <td>@(item.AnaliseTipo?.Descricao ?? "-")</td>
                                <td>@(item.AnaliseMetodo?.Descricao ?? "-")</td>
                                <td class="text-center">@item.QtdeAmostras</td>
                                <td class="text-end">@moedaSigla @item.VrUnitario.ToString("N2")</td>
                                <td class="text-end text-danger">@moedaSigla @item.VrDesconto.ToString("N2")</td>
                                <td class="text-end fw-semibold">@moedaSigla @item.VrTotal.ToString("N2")</td>
                                <td class="text-end">
                                    <form asp-action="RemoverItem" method="post" style="display:inline"
                                          onsubmit="return confirm('Remover este item?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="idItem" value="@item.Id" />
                                        <input type="hidden" name="idProposta" value="@Model.Id" />
                                        <button class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (Model.Analises.Any())
                    {
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="6" class="text-end fw-semibold">Total da Proposta:</td>
                                <td class="text-end fw-bold text-primary">@moedaSigla @Model.VrTotal.ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Popular ViewBag.Produtos etc. no formulário de item
</script>
}
