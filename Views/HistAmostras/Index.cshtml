@model IEnumerable<LabControl.Models.Laboratorio.HistAmostra>
@{
    ViewData["Title"] = "Amostras";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0"><i class="bi bi-droplet me-2 text-primary"></i>Amostras Recebidas</h5>
        <small class="text-muted">Registro e acompanhamento de amostras</small>
    </div>
    <a asp-action="Criar" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Nova Amostra
    </a>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-auto">
                <input type="text" class="form-control form-control-sm" name="busca" placeholder="Buscar cliente ou lote..." value="@ViewBag.Busca" />
            </div>
            <div class="col-auto">
                <select class="form-select form-select-sm" name="status">
                    <option value="">Todos os status</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Código</th>
                    <th>Cliente</th>
                    <th>Tipo de Análise</th>
                    <th>Produto / Lote</th>
                    <th>Data Entrega</th>
                    <th>Saldo</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            Nenhuma amostra registrada ainda.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="fw-semibold text-primary">@item.CodigoFormatado</span>
                        </td>
                        <td>@(item.Entidade?.Nome ?? "-")</td>
                        <td>@(item.AnaliseTipo?.Descricao ?? "-")</td>
                        <td>
                            @if (item.NrLote != null)
                            {
                                <span>@item.NrLote</span>
                            }
                            else { <span class="text-muted">-</span> }
                        </td>
                        <td>
                            @(item.DtEntrega.HasValue ? item.DtEntrega.Value.ToString("dd/MM/yyyy") : "-")
                        </td>
                        <td>
                            @if (item.Saldo != null)
                            {
                                <span class="@(item.Saldo.SaldoAtual > 0 ? "text-success" : "text-danger") fw-semibold">
                                    @item.Saldo.SaldoAtual.ToString("N2")
                                </span>
                            }
                            else { <span class="text-muted">-</span> }
                        </td>
                        <td>
                            @if (item.AmostraStatus != null)
                            {
                                <span class="badge badge-status" style="background-color: @(item.AmostraStatus.Cor ?? "#6c757d")">
                                    @item.AmostraStatus.Descricao
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Detalhes" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Any())
    {
        <div class="card-footer text-muted small">
            Total: @Model.Count() amostra(s)
        </div>
    }
</div>
