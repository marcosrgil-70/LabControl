@model LabControl.Models.Laboratorio.ParametroAnalise

<div class="card">
    <div class="card-header fw-semibold py-2">
        <i class="bi bi-sliders me-1"></i>Dados do Parâmetro
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">Descrição <span class="text-danger">*</span></label>
                <input asp-for="Descricao" class="form-control"
                       placeholder="Ex: Determinação de pH, Contagem de Coliformes..."
                       required maxlength="150" />
                <span asp-validation-for="Descricao" class="text-danger small"></span>
                <small class="text-muted">Nome completo do parâmetro/ensaio conforme laudo</small>
            </div>

            <div class="col-md-6">
                <label class="form-label">Tipo de Análise</label>
                <select asp-for="IdAnaliseTipo" class="form-select" id="selectAnaliseTipo">
                    <option value="">— Não vinculado —</option>
                    @foreach (var t in (List<LabControl.Models.Laboratorio.AnaliseTipo>)ViewBag.AnalisesTipos)
                    {
                        <option value="@t.Id" selected="@(Model.IdAnaliseTipo == t.Id)">@t.Descricao</option>
                    }
                </select>
                <small class="text-muted">Vincular ao tipo facilita filtragem nas propostas</small>
            </div>

            <div class="col-md-4">
                <label class="form-label">Valor Unitário (R$) <span class="text-danger">*</span></label>
                <div class="input-group">
                    <span class="input-group-text">R$</span>
                    <input asp-for="VrUnitario" type="number" step="0.01" min="0"
                           class="form-control" placeholder="0,00" required />
                </div>
                <span asp-validation-for="VrUnitario" class="text-danger small"></span>
                <small class="text-muted">Valor padrão usado ao adicionar em propostas</small>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <div class="alert alert-info py-2 px-3 mb-0 w-100 text-center small" id="previewValor">
                    <i class="bi bi-tag me-1"></i>
                    R$ <span id="valorPreview">@Model.VrUnitario.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelector('[name="VrUnitario"]').addEventListener('input', function () {
        const val = parseFloat(this.value) || 0;
        document.getElementById('valorPreview').textContent = val.toLocaleString('pt-BR', {
            minimumFractionDigits: 2, maximumFractionDigits: 2
        });
    });
</script>
}
