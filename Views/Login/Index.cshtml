@{
    ViewData["Title"] = "Login";
    Layout = null; // Tela de login sem menu lateral
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LabControl — Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #1a2f4e 0%, #2d5986 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            width: 380px;
            border: none;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        }
        .login-header {
            background: #1a2f4e;
            color: white;
            border-radius: 12px 12px 0 0;
            padding: 2rem;
            text-align: center;
        }
        .login-header i { font-size: 2.5rem; opacity: 0.9; }
        .login-header h4 { margin: 0.5rem 0 0; font-weight: 700; letter-spacing: 0.05em; }
        .login-header small { opacity: 0.65; }
    </style>
</head>
<body>
    <div class="card login-card">
        <div class="login-header">
            <i class="bi bi-flask"></i>
            <h4>LabControl</h4>
            <small>Sistema de Gestão Laboratorial</small>
        </div>
        <div class="card-body p-4">
            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger alert-sm py-2 small">
                    <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Erro
                </div>
            }

            <form asp-action="Index" asp-controller="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Usuário</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-person text-muted"></i>
                        </span>
                        <input name="login" type="text" class="form-control border-start-0 ps-0"
                               placeholder="Nome de usuário" autofocus required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold small">Senha</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="bi bi-lock text-muted"></i>
                        </span>
                        <input name="senha" type="password" class="form-control border-start-0 ps-0"
                               placeholder="Senha" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
                </button>
            </form>
        </div>
        <div class="card-footer text-center text-muted small py-2 bg-light rounded-bottom">
            LabControl &copy; @DateTime.Now.Year
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
