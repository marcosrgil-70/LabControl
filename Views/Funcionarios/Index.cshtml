@model IEnumerable<LabControl.Models.Entidades.Entidade>
@{
    ViewData["Title"] = "Funcionários";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0"><i class="bi bi-person-badge me-2 text-primary"></i>Funcionários</h5>
        <small class="text-muted">Cadastro de funcionários do laboratório</small>
    </div>
    <a asp-action="Criar" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Novo Funcionário
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-auto">
                <input type="text" class="form-control form-control-sm" name="busca"
                       placeholder="Buscar por nome..." value="@ViewBag.Busca" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Busca as string))
                {
                    <a asp-action="Index" class="btn btn-link btn-sm text-muted ms-1">Limpar</a>
                }
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 30%">Nome / Sobrenome</th>
                    <th style="width: 20%">Cargo</th>
                    <th style="width: 15%">CPF</th>
                    <th style="width: 15%">Telefone</th>
                    <th style="width: 12%">Situação</th>
                    <th style="width: 8%"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                            Nenhum funcionário cadastrado ainda.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="fw-semibold">@item.Nome</span>
                            @if (!string.IsNullOrWhiteSpace(item.PessoaFisica?.Sobrenome))
                            {
                                <br /><small class="text-muted">@item.PessoaFisica.Sobrenome</small>
                            }
                        </td>
                        <td class="text-muted">
                            @(item.Funcionario?.CargoFuncionario?.Descricao ?? "-")
                        </td>
                        <td class="text-muted">@(item.PessoaFisica?.Cpf ?? "-")</td>
                        <td class="text-muted">
                            @{
                                var fone = item.Fones.FirstOrDefault();
                                if (fone != null)
                                {
                                    @($"({fone.Ddd}) {fone.Fone}")
                                }
                                else { @("-") }
                            }
                        </td>
                        <td>
                            @if (item.Inativo)
                            {
                                <span class="badge bg-secondary">Inativo</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Ativo</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Editar" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Any())
    {
        <div class="card-footer text-muted small">
            Total: @Model.Count() funcionário(s)
        </div>
    }
</div>
