@model LabControl.Models.Laboratorio.Produto

<div class="row g-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold py-2">
                <i class="bi bi-box-seam me-1"></i>Dados do Produto
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Código <span class="text-danger">*</span></label>
                        <input asp-for="Codigo" class="form-control form-control-sm"
                               placeholder="Ex: PROD001" required maxlength="20" />
                        <span asp-validation-for="Codigo" class="text-danger small"></span>
                    </div>
                    <div class="col-md-9">
                        <label class="form-label">Descrição <span class="text-danger">*</span></label>
                        <input asp-for="Descricao" class="form-control form-control-sm"
                               placeholder="Nome completo do produto" required maxlength="150" />
                        <span asp-validation-for="Descricao" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold py-2">
                <i class="bi bi-archive me-1"></i>Embalagem
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Tipo de Embalagem</label>
                        <select asp-for="IdEmbalagemTipo" class="form-select form-select-sm">
                            <option value="">Selecione...</option>
                            @foreach (var e in (List<LabControl.Models.Laboratorio.EmbalagemTipo>)ViewBag.EmbalagensTopos)
                            {
                                <option value="@e.Id" selected="@(Model.IdEmbalagemTipo == e.Id)">
                                    @e.Descricao
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Quantidade por Embalagem</label>
                        <input asp-for="QtdeEmbalagem" type="number" step="0.01" min="0"
                               class="form-control form-control-sm" placeholder="Ex: 100" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Unidade de Medida</label>
                        <select asp-for="IdUnidade" class="form-select form-select-sm">
                            <option value="">Selecione...</option>
                            @foreach (var u in (List<LabControl.Models.Laboratorio.Unidade>)ViewBag.Unidades)
                            {
                                <option value="@u.Id" selected="@(Model.IdUnidade == u.Id)">
                                    @u.Sigla — @u.Descricao
                                </option>
                            }
                        </select>
                    </div>
                </div>
                <div class="mt-2">
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        Não encontrou a unidade ou embalagem?
                        <a asp-controller="TabelasAuxiliares" asp-action="Unidades" target="_blank">
                            Cadastrar unidade
                        </a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>
