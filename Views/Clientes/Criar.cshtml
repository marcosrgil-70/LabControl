@model LabControl.Models.Entidades.Entidade
@{
    ViewData["Title"] = "Novo Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-0"><i class="bi bi-person-plus me-2 text-primary"></i>Novo Cliente</h5>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<form asp-action="Criar" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold py-2">
                    <i class="bi bi-person me-1"></i>Dados Gerais
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Tipo de Pessoa <span class="text-danger">*</span></label>
                            <select asp-for="Categoria" class="form-select form-select-sm" id="tipoPessoa">
                                <option value="F">Pessoa Física</option>
                                <option value="J">Pessoa Jurídica</option>
                            </select>
                        </div>
                        <div class="col-md-9">
                            <label class="form-label">Nome / Razão Social <span class="text-danger">*</span></label>
                            <input asp-for="Nome" class="form-control form-control-sm" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fantasia <small class="text-muted">(nome resumido / apelido)</small></label>
                            <input name="fantasia" class="form-control form-control-sm"
                                   placeholder="Como o cliente é conhecido..." />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PF -->
        <div class="col-12" id="secaoPF">
            <div class="card">
                <div class="card-header fw-semibold py-2">
                    <i class="bi bi-person-badge me-1"></i>Dados Pessoa Física
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">CPF</label>
                            <input name="cpf" class="form-control form-control-sm" placeholder="000.000.000-00" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">RG</label>
                            <input name="rg" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Data de Nascimento</label>
                            <input name="dataNascimento" type="date" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Sexo</label>
                            <select name="sexo" class="form-select form-select-sm">
                                <option value="">-</option>
                                <option value="M">Masculino</option>
                                <option value="F">Feminino</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PJ -->
        <div class="col-12 d-none" id="secaoPJ">
            <div class="card">
                <div class="card-header fw-semibold py-2">
                    <i class="bi bi-building me-1"></i>Dados Pessoa Jurídica
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">CNPJ</label>
                            <input name="cnpj" class="form-control form-control-sm" placeholder="00.000.000/0000-00" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Nome Fantasia</label>
                            <input name="nomeFantasia" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Inscrição Estadual</label>
                            <input name="inscEstadual" class="form-control form-control-sm" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contato -->
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold py-2">
                    <i class="bi bi-telephone me-1"></i>Contato
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label">DDD</label>
                            <input name="ddd" class="form-control form-control-sm" maxlength="3" placeholder="11" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Telefone</label>
                            <input name="fone" class="form-control form-control-sm" placeholder="99999-9999" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i>Salvar Cliente
            </button>
        </div>
    </div>
</form>

@section Scripts {
<script>
    document.getElementById('tipoPessoa').addEventListener('change', function () {
        const isPF = this.value === 'F';
        document.getElementById('secaoPF').classList.toggle('d-none', !isPF);
        document.getElementById('secaoPJ').classList.toggle('d-none', isPF);
    });
</script>
}
