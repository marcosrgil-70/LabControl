@model LabControl.Models.Entidades.Entidade
@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Editar Cliente</h5>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Voltar</a>
</div>

<form asp-action="Editar" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold py-2">
                    <i class="bi bi-person me-1"></i>Dados Gerais
                    <span class="badge bg-secondary ms-2">ID: @Model.Id</span>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Tipo</label>
                            <input class="form-control form-control-sm" readonly
                                   value="@(Model.Categoria == "F" ? "Pessoa Física" : "Pessoa Jurídica")" />
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">Nome / Razão Social <span class="text-danger">*</span></label>
                            <input asp-for="Nome" class="form-control form-control-sm" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Inativo?</label>
                            <div class="form-check mt-1">
                                <input asp-for="Inativo" class="form-check-input" type="checkbox" />
                                <label class="form-check-label">Inativo</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Categoria == "F")
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header fw-semibold py-2"><i class="bi bi-person-badge me-1"></i>Pessoa Física</div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">CPF</label>
                                <input name="cpf" class="form-control form-control-sm"
                                       value="@Model.PessoaFisica?.Cpf" placeholder="000.000.000-00" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">RG</label>
                                <input name="rg" class="form-control form-control-sm" value="@Model.PessoaFisica?.Rg" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Nascimento</label>
                                <input name="dataNascimento" type="date" class="form-control form-control-sm"
                                       value="@Model.PessoaFisica?.DataNascimento?.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header fw-semibold py-2"><i class="bi bi-building me-1"></i>Pessoa Jurídica</div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">CNPJ</label>
                                <input name="cnpj" class="form-control form-control-sm"
                                       value="@Model.PessoaJuridica?.Cnpj" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Nome Fantasia</label>
                                <input name="nomeFantasia" class="form-control form-control-sm"
                                       value="@Model.PessoaJuridica?.NomeFantasia" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Inscrição Estadual</label>
                                <input name="inscEstadual" class="form-control form-control-sm"
                                       value="@Model.PessoaJuridica?.InscricaoEstadual" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="col-12 d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i>Salvar Alterações
            </button>
        </div>
    </div>
</form>
