@model List<LabControl.Models.Entidades.EntidadeFone>

@if (!Model.Any())
{
    <p class="text-muted text-center py-3 mb-0"><i class="bi bi-telephone-x me-1"></i>Nenhum telefone cadastrado.</p>
}
else
{
    <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>DDD</th>
                <th>Número</th>
                <th>Tipo</th>
                <th style="width:50px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in Model)
            {
                <tr>
                    <td class="align-middle">@(f.Ddd ?? "-")</td>
                    <td class="align-middle fw-semibold">@f.Fone</td>
                    <td class="align-middle">
                        @if (f.FoneTipo != null)
                        {
                            <span class="badge bg-light text-dark border">@f.FoneTipo.Descricao</span>
                        }
                        else { <span class="text-muted">-</span> }
                    </td>
                    <td class="text-end align-middle">
                        <button type="button" class="btn btn-outline-danger btn-sm"
                                onclick="excluirFone(@f.Id)"
                                title="Excluir">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
